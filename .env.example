# =============================================================
# Duneli — Environment Variable Template
# =============================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# .env is gitignored — NEVER commit real secrets to git.
#
# For production, use a proper secrets manager instead of .env:
#   - Railway:        Set vars in Railway dashboard (Project > Variables)
#   - AWS:            Use AWS Secrets Manager or Parameter Store
#   - Render/Heroku:  Use platform environment variable settings
#   - Self-hosted:    Use HashiCorp Vault or Docker secrets
# =============================================================

# -------------------------------------------------------------
# DATABASE
# Replace with your restricted duneli_app role credentials.
# Generate a strong password: openssl rand -base64 24
# After running prisma/sql/setup_restricted_role.sql, update below.
# -------------------------------------------------------------
DATABASE_URL="postgresql://duneli_app:YOUR_STRONG_PASSWORD@localhost:5432/duneli?schema=public&connection_limit=20&pool_timeout=10"

# -------------------------------------------------------------
# APPLICATION
# -------------------------------------------------------------
NODE_ENV="development"
PORT=3000

# -------------------------------------------------------------
# SESSION / JWT
# Generate with: openssl rand -base64 48
# -------------------------------------------------------------
SESSION_SECRET="GENERATE_WITH: node -e \"console.log(require('crypto').randomBytes(48).toString('hex'))\""

# -------------------------------------------------------------
# (Optional) AWS S3 — for off-site database backups
# -------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-south-1
# S3_BACKUP_BUCKET=your-bucket-name
