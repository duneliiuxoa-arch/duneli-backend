// ===================================================================
// DUNELI DATABASE SCHEMA - Prisma ORM
// PostgreSQL Database Design
// ===================================================================
// Primary key strategy:
//   uuid()  — core permanent tables (User, Topic, Meeting, Post, AuditLog, TopicScore)
//   cuid()  — high-write junction/engagement tables (votes, views, likes, chat, session, attendee)
// ===================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===================================================================
// ENUMS
// ===================================================================

enum UserRole {
  USER
  ADMIN
}

enum TopicStatus {
  ACTIVE
  CLOSED
  SELECTED
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}

// ===================================================================
// USER TABLE - PERMANENT DATA
// id = Supabase auth.users UUID (set by frontend after OAuth)
// password and Session removed — auth is handled by Supabase Auth
// ===================================================================
model User {
  id          String    @id  // Supabase auth.users UUID — no @default, set by app
  name        String    @db.VarChar(100)
  email       String    @unique @db.VarChar(255)
  avatarUrl   String?   @db.VarChar(500)
  anonymousId String?   @db.VarChar(20)
  role        UserRole  @default(USER)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  topics           Topic[]
  meetingAttendees MeetingAttendee[]
  postLikes        PostLike[]
  postViews        PostView[]
  auditLogs        AuditLog[]
  chatMessages     ChatMessage[]
  topicVotes       TopicVote[]
  ideaShares       IdeaShare[]

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

// ===================================================================
// TOPIC TABLE - TEMPORARY DATA
// ===================================================================
model Topic {
  id          String      @id @default(uuid())
  title       String      @db.VarChar(200)
  description String?     @db.Text
  status      TopicStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdById String

  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  meeting      Meeting?      @relation("TopicMeeting")
  topicScore   TopicScore?
  chatMessages ChatMessage[]
  votes        TopicVote[]
  ideaShares   IdeaShare[]

  // (status, createdAt) composite covers most list queries — standalone status/createdAt removed
  @@index([createdById])
  @@index([status, createdAt])
  @@map("topics")
}

// ===================================================================
// MEETING TABLE - PERMANENT DATA
// ===================================================================
model Meeting {
  id          String        @id @default(uuid())
  topicId     String        @unique
  meetingDate DateTime
  status      MeetingStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  topic        Topic             @relation("TopicMeeting", fields: [topicId], references: [id], onDelete: Restrict)
  attendees    MeetingAttendee[]
  post         Post?
  chatMessages ChatMessage[]

  // topicId @unique already creates an index — no duplicate @@index needed
  @@index([meetingDate])
  @@index([status])
  @@index([createdAt])
  @@map("meetings")
}

// ===================================================================
// POST TABLE - PERMANENT DATA
// ===================================================================
model Post {
  id        String    @id @default(uuid())
  title     String    @db.VarChar(300)
  content   String    @db.Text
  meetingId String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  meeting Meeting    @relation(fields: [meetingId], references: [id], onDelete: Restrict)
  views   PostView[]
  likes   PostLike[]

  // meetingId @unique already creates an index — @@index removed (was duplicate)
  @@map("posts")
}

// PostView — tracks unique views per user per post
// updatedAt removed: a view record never changes after creation
model PostView {
  id       String   @id @default(cuid())
  postId   String
  userId   String
  viewedAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_views")
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Restrict)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
  @@map("post_likes")
}

// TopicScore — computed score, auto-maintained by SQL triggers + sync job
// score changed Float → Int: formula always produces whole numbers
// topicId @@index removed: @unique already creates a B-tree index
model TopicScore {
  id           String   @id @default(uuid())
  topicId      String   @unique
  score        Int      @default(0)
  voteCount    Int      @default(0)
  messageCount Int      @default(0)
  meetingJoins Int      @default(0)
  calculatedAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Restrict)

  @@index([score])
  @@index([calculatedAt])
  @@map("topic_scores")
}

model TopicVote {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic Topic @relation(fields: [topicId], references: [id], onDelete: Restrict)
  user  User  @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([topicId, userId])
  @@index([topicId])
  @@index([userId])
  @@map("topic_votes")
}

// ChatMessage — topic OR meeting chat (CHECK constraint enforced via SQL migration)
// updatedAt added: needed when message editing is supported
// Redundant standalone topicId/meetingId indexes removed — composites cover them
model ChatMessage {
  id        String    @id @default(cuid())
  userId    String
  topicId   String?
  meetingId String?
  message   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user    User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  topic   Topic?   @relation(fields: [topicId], references: [id], onDelete: Restrict)
  meeting Meeting? @relation(fields: [meetingId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([topicId, createdAt])
  @@index([meetingId, createdAt])
  @@index([deletedAt])
  @@map("chat_messages")
}

// MeetingAttendee — permanent attendance record
// Added (userId, joinedAt) composite for user-history queries
model MeetingAttendee {
  id        String    @id @default(cuid())
  meetingId String
  userId    String
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  updatedAt DateTime  @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([meetingId, userId], name: "unique_meeting_attendee")
  @@index([meetingId, joinedAt])
  @@index([userId, joinedAt])
  @@map("meeting_attendees")
}

// IdeaShare — speaker/debater ideas shared during a meeting session
// One idea per user per 5 minutes (enforced in API layer)
// Reactions stored as counts + separate IdeaReaction join table
model IdeaShare {
  id        String   @id @default(cuid())
  topicId   String
  userId    String
  content   String   @db.VarChar(1000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  topic     Topic          @relation(fields: [topicId], references: [id], onDelete: Restrict)
  user      User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  reactions IdeaReaction[]

  @@index([topicId, createdAt])
  @@index([userId, createdAt])
  @@map("idea_shares")
}

// IdeaReaction — agree/disagree per user per idea (unique: one reaction per user)
model IdeaReaction {
  id        String   @id @default(cuid())
  ideaId    String
  userId    String
  type      String   @db.VarChar(10) // 'agree' | 'disagree'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idea IdeaShare @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([ideaId, userId])
  @@index([ideaId])
  @@map("idea_reactions")
}

// AuditLog — permanent security trail, RESTRICT delete (never cascade wipe)
model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?
  details    Json?
  ipAddress  String?  @db.VarChar(45)
  userAgent  String?  @db.VarChar(500)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([createdAt])
  @@index([action])
  @@map("audit_logs")
}
